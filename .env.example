# Discord
BOT_LOCALE=en
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ALLOWED_USER_IDS=
DISCORD_OWNER_USER_ID=
PALWORLD_AUDIT_LOG_CHANNEL_ID=

# Palworld REST API and status message
PALWORLD_STATUS_CHANNEL_ID=
PALWORLD_API_URL=http://127.0.0.1:8212/v1/api
PALWORLD_API_USERNAME=admin
PALWORLD_API_PASSWORD=
PALWORLD_UPDATE_INTERVAL_MS=60000

# Server command execution (local or remote)
PALWORLD_EXECUTION_MODE=local
# PALWORLD_SSH_BINARY=ssh
# PALWORLD_SSH_HOST=
# PALWORLD_SSH_PORT=22
# PALWORLD_SSH_USER=
# PALWORLD_SSH_IDENTITY_FILE=
# PALWORLD_SSH_KNOWN_HOSTS_FILE=
# PALWORLD_SSH_CONNECT_TIMEOUT_MS=10000

# LinuxGSM
LINUXGSM_USE_RUNUSER=true
LINUXGSM_USER=pwserver
LINUXGSM_SCRIPT=/home/pwserver/pwserver
LINUXGSM_CWD=/home/pwserver

# Maintenance
PM2_PROCESS_NAME=command-bot
PALWORLD_AUTO_UPDATE_CHECK_INTERVAL_MS=3600000
PALWORLD_RUNTIME_ALERT_COOLDOWN_MS=300000
PALWORLD_PM2_MONITOR_INTERVAL_MS=15000

# Feature flags (true or false)
FEATURE_SERVER_START_ENABLED=true
FEATURE_SERVER_STOP_ENABLED=true
FEATURE_SERVER_SAVE_ENABLED=true
FEATURE_SERVER_RESTART_ENABLED=true
FEATURE_MANUAL_REFRESH_ENABLED=true
FEATURE_ANNOUNCEMENTS_ENABLED=true
FEATURE_BOT_UPDATE_ENABLED=true
FEATURE_UPDATE_CHECK_ENABLED=true
FEATURE_UPDATE_INSTALL_ENABLED=true
FEATURE_AUTO_STATUS_UPDATES_ENABLED=true
FEATURE_AUDIT_LOG_ENABLED=true
FEATURE_AUTO_UPDATE_CHECK_ENABLED=true
FEATURE_DIAGNOSTICS_ENABLED=true
FEATURE_RUNTIME_ERROR_ALERTS_ENABLED=true
